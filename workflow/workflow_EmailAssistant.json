{
  "name": "IaEmail_Assistant",
  "nodes": [
    {
      "parameters": {
        "jsCode": "return items.filter(item => {\n  const labels = (item.json.labels || []).map(label => label.name);\n\n  return !labels.includes(\"PROCESSED_AI\");\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [352,144],
      "name": "Remove mensagens já analisadas"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const email = item.json;\n  let text = email.snippet || \"\";\n  return {\n    json: {\n      id: email.id,\n      from: email.From,\n      subject: email.Subject,\n      text: text,\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [528,144],
      "name": "formata dados das mensagens"
    },
    {
      "parameters": {
        "operation": "getAll",
        "limit": 10
      },
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.2,
      "position": [176,96],
      "name": "Busca as dez ultimas mensagens"
    },
    {
      "parameters": {
        "operation": "addLabels",
        "messageId": "={{ $json.id }}",
        "labelIds": ["Label_6668027004043354001"]
      },
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.2,
      "position": [1136,224],
      "name": "Add marcador"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  let content = item.json.choices[0].message.content;\n  content = content.replace(/```json|```/g, \"\").trim();\n  const parsed = JSON.parse(content);\n  return {\n    json: {\n      id: parsed.id,\n      subject: parsed.subject,\n      from: parsed.from,\n      resumo: parsed.resumo,\n      acao: parsed.acao\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [944,96],
      "name": "Formata dados da API"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "jsonHeaders": "{\n  \"Authorization\": \"Bearer {{$env.GROQ_API_KEY}}\",\n  \"Content-Type\": \"application/json\"\n}",
        "sendBody": true,
        "jsonBody": "={ \"model\": \"llama-3.3-70b-versatile\" }"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [784,96],
      "name": "Groq API"
    },
    {
      "parameters": {
        "rule": {
          "interval": [{ "triggerAtHour": 7 }]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [16,96],
      "name": "Schedule Trigger"
